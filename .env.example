# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# For Vercel: Add this to your Project Settings > Environment Variables.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# AI Studio automatically injects this at runtime.
# For Vercel: This will be your vercel deployment URL (e.g., https://my-app.vercel.app).
APP_URL="MY_APP_URL"

# Access Code for the website gate
VITE_ACCESS_CODE=8052

# Note: Firebase configuration is currently loaded from firebase-applet-config.json.
# If you want to use environment variables for Firebase, you can update src/firebase.ts.
