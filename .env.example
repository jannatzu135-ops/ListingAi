# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# For Vercel: Add this to your Project Settings > Environment Variables.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# AI Studio automatically injects this at runtime.
# For Vercel: This will be your vercel deployment URL (e.g., https://my-app.vercel.app).
APP_URL="MY_APP_URL"

# Access Code for the website gate
VITE_ACCESS_CODE=8052

# Firebase Configuration (Required for GitHub Pages / Vercel)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# Gemini API Key (Required for AI features)
VITE_GEMINI_API_KEY=
